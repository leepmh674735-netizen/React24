const useZuStore = create(
    (set, get => ({
        
        상태변수1: 초깃값1,
        상태변수2 : 초깃값2,
        
        함수명1: (매개변수) => set((state) => ({
            상태변수 : 변경할값
        })),

        함수명2 : (매개변수) => {
            const 현재 값 = get().상태변수1;
            set({ 상태변수2 : 현제 값 + 매개변수 });
        },
    })
);
 
const { 상태변수1, 상태변수2, 함수명1, 함수명2 } = useZuStore();


